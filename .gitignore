# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Project-specific: raw/cached data pulls ---
# These are large, re-pullable, and shouldn't bloat the repo. Keep the
# scripts, not the outputs. Remove these lines if you want to version
# a frozen dataset for reproducibility (e.g. before a final paper submission).
/data/*.csv
/data/*.parquet
/data/raw/
/data/cache/

# --- Project-specific: generated figures/tables ---
# Regeneratable from /backtest + /optimization; keep out of version control
# unless you want to pin exact figures used in the paper draft.
/figures/*.png
/figures/*.pdf
/figures/*.svg

# --- Secrets ---
# FRED API key, or any .env file with credentials
.env
*.key
secrets.json

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
